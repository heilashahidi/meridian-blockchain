# Meridian automation service — environment variables.
# Copy to `.env` and adjust. Every var is OPTIONAL; the documented default is
# used when unset. Values here are safe placeholders, not secrets.

# ─── cluster + oracle ────────────────────────────────────────────────────────

# Solana RPC endpoint the jobs read/write against.
RPC_URL=https://api.devnet.solana.com

# Pyth Hermes endpoint (price reads: previous-close + latest + post blobs).
HERMES_URL=https://hermes.pyth.network

# Pyth receiver program id (settle posts price updates here). Default is the
# canonical devnet/mainnet receiver already stored in on-chain Config.
PYTH_RECEIVER=rec5EKMGg6MxZYaMdyBfgwp4d5rB9T1VQH5pJv5LtFJ

# Path to the admin keypair JSON (signs create_strike_market / settle). The
# leading ~ is expanded to your home directory.
ADMIN_KEYPAIR=~/.config/solana/id.json

# ─── tickers + strike ladder ─────────────────────────────────────────────────

# Comma-separated subset of the MAG7 to operate on. Unset → all 7
# (AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA). Use a subset for a faster demo.
TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA

# Percentage offsets (±each) from the previous close for the strike ladder.
STRIKE_PERCENTS=3,6,9

# Round each strike to the nearest multiple of this many dollars.
STRIKE_ROUNDING=10

# Fixed-dollar strike step (e.g. 10 → strikes every $10). When set, the ladder
# is center ± N·step and STRIKE_PERCENTS is ignored. Unset → percentage ladder.
STRIKE_STEP_DOLLARS=10

# Strikes each side of center in fixed-step mode (N). Default 3 → 7 strikes.
STRIKE_STEP_COUNT=3

# Market expiry horizon in hours from the run (create-strikes). Default 24.
EXPIRY_HOURS_FROM_NOW=24

# ─── settle job ──────────────────────────────────────────────────────────────

# Per-RPC-call timeout in milliseconds for the settle job. Default 60000.
CALL_TIMEOUT_MS=60000

# Admin-override fallback prices when the oracle is stale/off-hours. Comma-
# separated TICKER=price, e.g. AAPL=187.5,NVDA=120. Unset → no overrides.
OVERRIDE_PRICES=

# ─── demo + scheduler ────────────────────────────────────────────────────────

# "true" → after create-strikes, rest a small bid+ask on each fresh market so
# the board shows implied odds immediately. Off by default (PRD-pure).
SEED_LIQUIDITY=false

# (schedule) ET wall-clock time for the morning create-strikes job, HH:MM.
SCHEDULE_MORNING_ET=08:00

# (schedule) ET wall-clock time for the after-close settle job, HH:MM.
SCHEDULE_SETTLE_ET=16:05

# (schedule) Scheduler poll interval in milliseconds. Default 60000.
SCHEDULE_TICK_MS=60000

# ─── logging + alerting ──────────────────────────────────────────────────────

# Log verbosity: debug | info | warn | error. Default info.
LOG_LEVEL=info

# Optional webhook URL; alert() escalations are best-effort POSTed here as JSON.
ALERT_WEBHOOK=
