# Meridian on-chain CLOB — environment template
# Copy to .env (gitignored) and fill in.

# Anchor / Solana provider
# ANCHOR_PROVIDER_URL points at the cluster RPC; ANCHOR_WALLET at the keypair file.
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json

# Meridian program ID — overwritten with the real key after first `anchor build`
# generates target/deploy/meridian-keypair.json. Defaults to Anchor's placeholder
# so `anchor build` works on a clean clone.
MERIDIAN_PROGRAM_ID=6oe2PzNoWyLMrWHqGAj5hirRUX68z35oqBTW9T1E9mWX

# Pyth Solana receiver (U7 — wired when settle_market lands)
# Devnet receiver program ID. See pyth-solana-receiver-sdk docs.
PYTH_RECEIVER_PROGRAM_ID=rec5EKMGg6MxZYaMdyBfgwp4d5rB9T1VQH5pJv5LtFJ
# Per-ticker Pyth price feed IDs (hex). Pin during U3 from Pyth's published
# devnet feed list — placeholders below.
PYTH_FEED_AAPL=
PYTH_FEED_MSFT=
PYTH_FEED_GOOGL=
PYTH_FEED_AMZN=
PYTH_FEED_NVDA=
PYTH_FEED_META=
PYTH_FEED_TSLA=

# USDC mint on devnet (used by Config + escrow PDAs from U3 onward).
# Circle's canonical devnet USDC mint:
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Admin keypair (devnet only) — used by lifecycle automation scripts later
# to call initialize_config / create_strike_market. Leave unset for local-only work.
MERIDIAN_ADMIN_KEYPAIR=
