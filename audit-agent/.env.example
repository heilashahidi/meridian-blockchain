# The auditor calls Claude via @langchain/anthropic. Reuse the same key the app
# uses for the market-chat (app/.env.local has ANTHROPIC_API_KEY).
ANTHROPIC_API_KEY=sk-ant-...

# Model that drives hypothesize/judge. Sonnet 4.6 is the default — strong
# reasoning at a sane cost for iterative runs. Bump to claude-opus-4-8 for the
# deepest pass.
AUDIT_MODEL=claude-sonnet-4-6

# How many instruction files to audit in one run (budget guard). 0 = all.
AUDIT_MAX_TARGETS=0

# Allow the slow deep-verify probe (trident fuzz). Off by default because a
# build+fuzz cycle is minutes; the fast static+cargo probes run every time.
AUDIT_ENABLE_TRIDENT=0
