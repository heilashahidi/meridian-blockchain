{
  "name": "meridian-app",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal trade-loop frontend for the Meridian on-chain CLOB.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/web3.js": "^1.95.3",
    "buffer": "^6.0.3",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  },
  "comment:overrides": "The wallet-adapter dependency tree pulls @types/react@19 nested, which collides with this app's React 18 JSX types (ConnectionProvider becomes 'not a valid JSX element type'). Pin the types to 18.x everywhere so the build is consistent and the lockfile resolves deterministically.",
  "overrides": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0"
  }
}
